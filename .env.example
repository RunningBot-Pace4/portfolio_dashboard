# Neon Postgres connection string.
# Get it from Neon Console > Project > Connect.
# Keep sslmode=require or channel_binding=require in the URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require"

# Optional but recommended for your public Vercel URL.
BASIC_AUTH_USERNAME="admin"
BASIC_AUTH_PASSWORD="change-this-password"

# Optional market price cache.
PRICE_CACHE_SECONDS="300"
